# Copy this file to .streamlit/secrets.toml (gitignored, never commit real values)
# and fill in your own PayPal SANDBOX credentials to start.
#
# On Streamlit Community Cloud, don't upload this file — instead paste the
# same [paypal] table into your app's Settings > Secrets.

[paypal]
client_id = "..."          # developer.paypal.com > Dashboard > Apps & Credentials (Sandbox) > your app
client_secret = "..."      # same place
plan_id = "..."            # from scripts/setup_paypal_plan.py, see below
mode = "sandbox"           # switch to "live" only once you're ready for real payments
app_base_url = "http://localhost:8501"   # use https://master-data-explorer-pro.streamlit.app in prod secrets

[sendgrid]
api_key = "..."             # app.sendgrid.com > Settings > API Keys > Create API Key (Restricted Access: Mail Send only)
from_email = "..."          # a sender you've verified in SendGrid (Settings > Sender Authentication)
